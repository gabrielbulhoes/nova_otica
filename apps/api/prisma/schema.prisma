// Nova Г“tica вЂ” modelo de dados
// Espelha as entidades da API Sellbie/CDS e adiciona a camada de
// movimentaГ§ГЈo interna (transferГЄncias/ajustes) usada em tempo real
// durante o dia, reconciliada a cada sincronizaГ§ГЈo da manhГЈ (06:00-07:00).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// в”Ђв”Ђв”Ђ Cadastros base в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

/// Loja / filial da rede (Sellbie: rota `lojas`, campo `idFilial`).
model Store {
  id         String  @id @default(cuid())
  externalId String  @unique // idFilial
  code       String? // cГіdigo interno da filial
  name       String
  city       String?
  state      String?
  phone      String?
  active     Boolean @default(true)

  syncedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  stockItems    StockItem[]
  sales         Sale[]
  sellers       Seller[]
  users         User[]
  carts         Cart[]
  orders        Order[]
  movementsFrom InventoryMovement[] @relation("MovementFromStore")
  movementsTo   InventoryMovement[] @relation("MovementToStore")

  @@index([active])
}

enum Role {
  ADMIN // gestor da rede вЂ” acesso total
  STORE_MANAGER // gestor de loja вЂ” escopo restrito Г  prГіpria filial
}

/// UsuГЎrio da plataforma. ADMIN enxerga toda a rede; STORE_MANAGER Г©
/// limitado Г  `storeId` (estoque, vendas e movimentaГ§Гµes da sua loja).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(STORE_MANAGER)
  storeId      String?
  active       Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store Store? @relation(fields: [storeId], references: [id])

  @@index([role])
}

/// Vendedor / funcionГЎrio (Sellbie: rota `vendedores`, campo `funcionario`).
model Seller {
  id         String  @id @default(cuid())
  externalId String  @unique // funcionario
  name       String
  storeId    String?
  active     Boolean @default(true)

  includedAt DateTime? // dataInclusao
  syncedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  store Store?  @relation(fields: [storeId], references: [id])
  sales Sale[]

  @@index([storeId])
}

/// Cor de produto (Sellbie: rota `cores`).
model Color {
  id         String  @id @default(cuid())
  externalId String  @unique
  name       String
  hex        String?

  syncedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products Product[]
}

/// Tamanho de produto (Sellbie: rota `tamanhos`).
model Size {
  id         String @id @default(cuid())
  externalId String @unique
  name       String

  syncedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products Product[]
}

/// Produto (Sellbie: rota `produtos`, campo `prodCodigo`).
model Product {
  id          String   @id @default(cuid())
  externalId  String   @unique // prodCodigo
  sku         String?
  description String
  brand       String?
  category    String? // armaГ§ГЈo, lente, Гіculos de sol, acessГіrio, etc.
  colorId     String?
  sizeId      String?
  price       Decimal? @db.Decimal(12, 2)
  cost        Decimal? @db.Decimal(12, 2)
  minStock    Int? // estoque mГ­nimo por loja (dispara alerta de ruptura)
  active      Boolean  @default(true)

  includedAt DateTime? // dataInclusao
  syncedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  color       Color?              @relation(fields: [colorId], references: [id])
  size        Size?               @relation(fields: [sizeId], references: [id])
  stockItems  StockItem[]
  saleItems   SaleItem[]
  movements   InventoryMovement[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  assets      ProductAsset[]
  tryOnEvents TryOnEvent[]

  @@index([category])
  @@index([brand])
}

/// Cliente (Sellbie: rota `clientes`, campo `cpfCnpj`).
model Customer {
  id         String  @id @default(cuid())
  externalId String  @unique
  document   String? // cpfCnpj
  name       String
  email      String?
  phone      String?
  city       String?
  state      String?

  includedAt DateTime? // dataInclusao
  syncedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sales Sale[]

  @@index([document])
}

// в”Ђв”Ђв”Ђ Estoque в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

/// PosiГ§ГЈo de estoque de um produto em uma loja (Sellbie: rota `estoque`).
/// `quantity` Г© o valor sincronizado da fonte; `available` reflete o filtro
/// `only_disp`. `reserved`/`onHand` sГЈo derivados das movimentaГ§Гµes internas.
model StockItem {
  id        String @id @default(cuid())
  storeId   String
  productId String

  quantity  Int @default(0) // quantidade vinda do Sellbie na Гєltima sync
  available Int @default(0) // disponГ­vel (only_disp) na Гєltima sync
  reserved  Int @default(0) // reservado por movimentaГ§Гµes internas pendentes

  syncedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([storeId, productId])
  @@index([productId])
}

// в”Ђв”Ђв”Ђ Vendas в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

/// Venda (Sellbie: rotas `vendas` / `detalhesVendas`, campo `dataVenda`).
model Sale {
  id         String   @id @default(cuid())
  externalId String   @unique
  storeId    String?
  sellerId   String?
  customerId String?
  saleDate   DateTime
  total      Decimal  @db.Decimal(12, 2)
  discount   Decimal? @db.Decimal(12, 2)
  status     String?

  syncedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  store    Store?     @relation(fields: [storeId], references: [id])
  seller   Seller?    @relation(fields: [sellerId], references: [id])
  customer Customer?  @relation(fields: [customerId], references: [id])
  items    SaleItem[]
  payments Payment[]

  @@index([saleDate])
  @@index([storeId])
}

/// Item de uma venda (Sellbie: rota `detalhesVendas`).
model SaleItem {
  id         String   @id @default(cuid())
  externalId String?  @unique
  saleId     String
  productId  String?
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(12, 2)
  discount   Decimal? @db.Decimal(12, 2)
  total      Decimal  @db.Decimal(12, 2)

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

/// Pagamento de uma venda (Sellbie: rota `pagamentosVendas`).
model Payment {
  id           String    @id @default(cuid())
  externalId   String?   @unique
  saleId       String
  method       String? // dinheiro, cartГЈo, pix, crediГЎrio...
  amount       Decimal   @db.Decimal(12, 2)
  installments Int?
  paidAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

// в”Ђв”Ђв”Ђ MovimentaГ§ГЈo interna (tempo real durante o dia) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum MovementType {
  TRANSFER // transferГЄncia entre lojas
  SALE // saГ­da por venda registrada internamente
  ADJUSTMENT // ajuste manual de estoque
  RETURN // devoluГ§ГЈo / entrada
}

enum MovementStatus {
  REQUESTED // solicitada por uma loja, aguardando aprovaГ§ГЈo da rede
  REJECTED // solicitaГ§ГЈo recusada
  PENDING // aprovada/registrada, reserva o saldo na origem
  CONFIRMED // efetivada no estoque interno
  CANCELLED // cancelada
  RECONCILED // jГЎ refletida pela sincronizaГ§ГЈo da fonte
}

/// MovimentaГ§ГЈo de estoque feita dentro da plataforma ao longo do dia.
/// Permite operar em "tempo real" mesmo com a fonte disponГ­vel sГі Г s 06h:
/// o estoque exibido = base sincronizada + movimentaГ§Гµes nГЈo reconciliadas.
model InventoryMovement {
  id          String         @id @default(cuid())
  type        MovementType
  status      MovementStatus @default(PENDING)
  productId   String
  fromStoreId String? // origem (TRANSFER/SALE/ADJUSTMENT-)
  toStoreId   String? // destino (TRANSFER/RETURN/ADJUSTMENT+)
  quantity    Int
  reason      String?
  reference   String? // ex.: nВє da venda/OS de origem
  createdBy   String? // usuГЎrio que registrou/solicitou
  approvedBy  String? // usuГЎrio que aprovou/rejeitou
  decisionNote String? // justificativa da aprovaГ§ГЈo/recusa

  createdAt    DateTime  @default(now())
  approvedAt   DateTime?
  confirmedAt  DateTime?
  reconciledAt DateTime?

  product   Product @relation(fields: [productId], references: [id])
  fromStore Store?  @relation("MovementFromStore", fields: [fromStoreId], references: [id])
  toStore   Store?  @relation("MovementToStore", fields: [toStoreId], references: [id])

  @@index([status])
  @@index([productId])
  @@index([createdAt])
}

// в”Ђв”Ђв”Ђ Auditoria de sincronizaГ§ГЈo в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum SyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

/// Registro de cada execuГ§ГЈo de sincronizaГ§ГЈo (por entidade ou geral).
model SyncRun {
  id             String     @id @default(cuid())
  entity         String // "all", "stores", "products", "stock", ...
  status         SyncStatus @default(RUNNING)
  startedAt      DateTime   @default(now())
  finishedAt     DateTime?
  recordsRead    Int        @default(0)
  recordsWritten Int        @default(0)
  window         String? // janela usada, ex.: "06:00-07:00"
  trigger        String? // "schedule", "boot", "manual"
  error          String?

  @@index([entity])
  @@index([startedAt])
}

// в”Ђв”Ђв”Ђ E-commerce (venda online) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

/// Carrinho de compras (por usuГЎrio/sessГЈo), sempre atrelado a uma loja de
/// origem do estoque.
model Cart {
  id        String     @id @default(cuid())
  userId    String?
  storeId   String
  status    String     @default("OPEN") // OPEN | CONVERTED | ABANDONED
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  store     Store      @relation(fields: [storeId], references: [id])
  items     CartItem[]

  @@index([userId])
  @@index([status])
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int     @default(1)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

enum OrderStatus {
  CREATED // aguardando pagamento
  PAID // pagamento confirmado
  FULFILLED // separado/entregue
  CANCELLED
  REFUNDED
}

/// Pedido de venda online.
model Order {
  id           String      @id @default(cuid())
  number       String      @unique
  userId       String?
  storeId      String
  customerName String?
  status       OrderStatus @default(CREATED)
  subtotal     Decimal     @db.Decimal(12, 2)
  total        Decimal     @db.Decimal(12, 2)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  paidAt       DateTime?

  store   Store          @relation(fields: [storeId], references: [id])
  items   OrderItem[]
  payment OnlinePayment?

  @@index([status])
  @@index([storeId])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(12, 2)
  total      Decimal @db.Decimal(12, 2)
  movementId String? // reserva de estoque associada (InventoryMovement)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

enum OnlinePaymentStatus {
  PENDING
  APPROVED
  DECLINED
  REFUNDED
}

/// Pagamento online do pedido, abstraГ­do do gateway (provider).
model OnlinePayment {
  id         String              @id @default(cuid())
  orderId    String              @unique
  provider   String // "mock" | "mercadopago" | ...
  method     String? // PIX | CARD | BOLETO
  status     OnlinePaymentStatus @default(PENDING)
  amount     Decimal             @db.Decimal(12, 2)
  externalId String? // id no gateway
  qrCode     String? // payload PIX (mock)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
}

// в”Ђв”Ђв”Ђ Provador Virtual (AR) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum AssetType {
  GLB_3D // modelo 3D em escala real (projeГ§ГЈo exata)
  OVERLAY_2D // overlay 2D (fallback)
}

enum AssetStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// Asset de AR de um produto (modelo 3D/2D + metadados de encaixe).
model ProductAsset {
  id        String      @id @default(cuid())
  productId String
  type      AssetType
  url       String
  fit       Json? // { frameWidth, bridgeWidth, templeLength, lensHeight, scale, ... }
  version   Int         @default(1)
  status    AssetStatus @default(PUBLISHED)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([status])
}

/// Telemetria de prova virtual (alimenta o funil no BI). Sem dados biomГ©tricos.
model TryOnEvent {
  id         String   @id @default(cuid())
  productId  String
  storeId    String?
  userId     String?
  durationMs Int?
  converted  Boolean  @default(false)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([createdAt])
}
