// Nova Ótica — modelo de dados
// Espelha as entidades da API Sellbie/CDS e adiciona a camada de
// movimentação interna (transferências/ajustes) usada em tempo real
// durante o dia, reconciliada a cada sincronização da manhã (06:00-07:00).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Cadastros base ──────────────────────────────────────────────────────────

/// Loja / filial da rede (Sellbie: rota `lojas`, campo `idFilial`).
model Store {
  id         String  @id @default(cuid())
  externalId String  @unique // idFilial
  code       String? // código interno da filial
  name       String
  city       String?
  state      String?
  phone      String?
  active     Boolean @default(true)

  syncedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  stockItems    StockItem[]
  sales         Sale[]
  sellers       Seller[]
  movementsFrom InventoryMovement[] @relation("MovementFromStore")
  movementsTo   InventoryMovement[] @relation("MovementToStore")

  @@index([active])
}

/// Vendedor / funcionário (Sellbie: rota `vendedores`, campo `funcionario`).
model Seller {
  id         String  @id @default(cuid())
  externalId String  @unique // funcionario
  name       String
  storeId    String?
  active     Boolean @default(true)

  includedAt DateTime? // dataInclusao
  syncedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  store Store?  @relation(fields: [storeId], references: [id])
  sales Sale[]

  @@index([storeId])
}

/// Cor de produto (Sellbie: rota `cores`).
model Color {
  id         String  @id @default(cuid())
  externalId String  @unique
  name       String
  hex        String?

  syncedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products Product[]
}

/// Tamanho de produto (Sellbie: rota `tamanhos`).
model Size {
  id         String @id @default(cuid())
  externalId String @unique
  name       String

  syncedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products Product[]
}

/// Produto (Sellbie: rota `produtos`, campo `prodCodigo`).
model Product {
  id          String   @id @default(cuid())
  externalId  String   @unique // prodCodigo
  sku         String?
  description String
  brand       String?
  category    String? // armação, lente, óculos de sol, acessório, etc.
  colorId     String?
  sizeId      String?
  price       Decimal? @db.Decimal(12, 2)
  cost        Decimal? @db.Decimal(12, 2)
  active      Boolean  @default(true)

  includedAt DateTime? // dataInclusao
  syncedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  color      Color?              @relation(fields: [colorId], references: [id])
  size       Size?               @relation(fields: [sizeId], references: [id])
  stockItems StockItem[]
  saleItems  SaleItem[]
  movements  InventoryMovement[]

  @@index([category])
  @@index([brand])
}

/// Cliente (Sellbie: rota `clientes`, campo `cpfCnpj`).
model Customer {
  id         String  @id @default(cuid())
  externalId String  @unique
  document   String? // cpfCnpj
  name       String
  email      String?
  phone      String?
  city       String?
  state      String?

  includedAt DateTime? // dataInclusao
  syncedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  sales Sale[]

  @@index([document])
}

// ─── Estoque ─────────────────────────────────────────────────────────────────

/// Posição de estoque de um produto em uma loja (Sellbie: rota `estoque`).
/// `quantity` é o valor sincronizado da fonte; `available` reflete o filtro
/// `only_disp`. `reserved`/`onHand` são derivados das movimentações internas.
model StockItem {
  id        String @id @default(cuid())
  storeId   String
  productId String

  quantity  Int @default(0) // quantidade vinda do Sellbie na última sync
  available Int @default(0) // disponível (only_disp) na última sync
  reserved  Int @default(0) // reservado por movimentações internas pendentes

  syncedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([storeId, productId])
  @@index([productId])
}

// ─── Vendas ──────────────────────────────────────────────────────────────────

/// Venda (Sellbie: rotas `vendas` / `detalhesVendas`, campo `dataVenda`).
model Sale {
  id         String   @id @default(cuid())
  externalId String   @unique
  storeId    String?
  sellerId   String?
  customerId String?
  saleDate   DateTime
  total      Decimal  @db.Decimal(12, 2)
  discount   Decimal? @db.Decimal(12, 2)
  status     String?

  syncedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  store    Store?     @relation(fields: [storeId], references: [id])
  seller   Seller?    @relation(fields: [sellerId], references: [id])
  customer Customer?  @relation(fields: [customerId], references: [id])
  items    SaleItem[]
  payments Payment[]

  @@index([saleDate])
  @@index([storeId])
}

/// Item de uma venda (Sellbie: rota `detalhesVendas`).
model SaleItem {
  id         String   @id @default(cuid())
  externalId String?  @unique
  saleId     String
  productId  String?
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(12, 2)
  discount   Decimal? @db.Decimal(12, 2)
  total      Decimal  @db.Decimal(12, 2)

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

/// Pagamento de uma venda (Sellbie: rota `pagamentosVendas`).
model Payment {
  id           String    @id @default(cuid())
  externalId   String?   @unique
  saleId       String
  method       String? // dinheiro, cartão, pix, crediário...
  amount       Decimal   @db.Decimal(12, 2)
  installments Int?
  paidAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

// ─── Movimentação interna (tempo real durante o dia) ─────────────────────────

enum MovementType {
  TRANSFER // transferência entre lojas
  SALE // saída por venda registrada internamente
  ADJUSTMENT // ajuste manual de estoque
  RETURN // devolução / entrada
}

enum MovementStatus {
  PENDING // registrada, aguardando confirmação
  CONFIRMED // efetivada no estoque interno
  CANCELLED // cancelada
  RECONCILED // já refletida pela sincronização da fonte
}

/// Movimentação de estoque feita dentro da plataforma ao longo do dia.
/// Permite operar em "tempo real" mesmo com a fonte disponível só às 06h:
/// o estoque exibido = base sincronizada + movimentações não reconciliadas.
model InventoryMovement {
  id          String         @id @default(cuid())
  type        MovementType
  status      MovementStatus @default(PENDING)
  productId   String
  fromStoreId String? // origem (TRANSFER/SALE/ADJUSTMENT-)
  toStoreId   String? // destino (TRANSFER/RETURN/ADJUSTMENT+)
  quantity    Int
  reason      String?
  reference   String? // ex.: nº da venda/OS de origem
  createdBy   String? // usuário que registrou

  createdAt    DateTime  @default(now())
  confirmedAt  DateTime?
  reconciledAt DateTime?

  product   Product @relation(fields: [productId], references: [id])
  fromStore Store?  @relation("MovementFromStore", fields: [fromStoreId], references: [id])
  toStore   Store?  @relation("MovementToStore", fields: [toStoreId], references: [id])

  @@index([status])
  @@index([productId])
  @@index([createdAt])
}

// ─── Auditoria de sincronização ──────────────────────────────────────────────

enum SyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

/// Registro de cada execução de sincronização (por entidade ou geral).
model SyncRun {
  id             String     @id @default(cuid())
  entity         String // "all", "stores", "products", "stock", ...
  status         SyncStatus @default(RUNNING)
  startedAt      DateTime   @default(now())
  finishedAt     DateTime?
  recordsRead    Int        @default(0)
  recordsWritten Int        @default(0)
  window         String? // janela usada, ex.: "06:00-07:00"
  trigger        String? // "schedule", "boot", "manual"
  error          String?

  @@index([entity])
  @@index([startedAt])
}
