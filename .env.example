# ─── Banco de dados (PostgreSQL) ─────────────────────────────────────────────
POSTGRES_USER=nova_otica
POSTGRES_PASSWORD=nova_otica
POSTGRES_DB=nova_otica
POSTGRES_PORT=5432
DATABASE_URL=postgresql://nova_otica:nova_otica@localhost:5432/nova_otica?schema=public

# ─── API (backend) ───────────────────────────────────────────────────────────
API_PORT=3333
NODE_ENV=development
# Origem permitida para o frontend (CORS)
WEB_ORIGIN=http://localhost:5173

# Autenticação (JWT). Troque o segredo em produção.
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=8h
# Estoque mínimo padrão da rede quando o produto não define o seu (alertas).
DEFAULT_MIN_STOCK=3
# Usuário administrador criado no seed.
SEED_ADMIN_EMAIL=admin@novaotica.com
SEED_ADMIN_PASSWORD=admin123

# ─── Integração Sellbie / CDS ────────────────────────────────────────────────
# Modo da integração: "mock" gera dados de demonstração sem credenciais reais.
# Troque para "live" quando tiver a URL base e a autenticação.
SELLBIE_MODE=mock
SELLBIE_BASE_URL=https://api.exemplo-cds.com.br
SELLBIE_API_KEY=
SELLBIE_USERNAME=
SELLBIE_PASSWORD=

# Janela de uso permitida pela API (horário local). A integração só chama a API
# real dentro desta janela; fora dela as chamadas são bloqueadas.
SELLBIE_WINDOW_START=06:00
SELLBIE_WINDOW_END=07:00
# Defina como "true" para ignorar a trava de janela (útil em testes/homologação).
SELLBIE_IGNORE_WINDOW=false

# ─── Sincronização ───────────────────────────────────────────────────────────
# Expressão cron do job diário (padrão: 06:00 todos os dias).
SYNC_CRON=0 6 * * *
# Fuso usado pelo agendador.
SYNC_TIMEZONE=America/Sao_Paulo
# Rodar uma sincronização ao iniciar a API (em mock, recomendado true).
SYNC_ON_BOOT=true
