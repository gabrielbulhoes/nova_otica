# ─── Banco de dados (PostgreSQL) ─────────────────────────────────────────────
POSTGRES_USER=nova_otica
POSTGRES_PASSWORD=nova_otica
POSTGRES_DB=nova_otica
POSTGRES_PORT=5432
DATABASE_URL=postgresql://nova_otica:nova_otica@localhost:5432/nova_otica?schema=public

# ─── API (backend) ───────────────────────────────────────────────────────────
API_PORT=3333
NODE_ENV=development
# Origem permitida para o frontend (CORS)
WEB_ORIGIN=http://localhost:5173

# Autenticação (JWT). Troque o segredo em produção.
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=8h
# Estoque mínimo padrão da rede quando o produto não define o seu (alertas).
DEFAULT_MIN_STOCK=3
# Usuário administrador criado no seed.
SEED_ADMIN_EMAIL=admin@novaotica.com
SEED_ADMIN_PASSWORD=admin123

# ─── Integração CDS (conector Sellbie) ───────────────────────────────────────
# Modo: "mock" gera dados de demonstração sem credenciais. Troque para "live"
# quando tiver a URL base e os três cabeçalhos de autenticação da CDS.
SELLBIE_MODE=mock
# Base do conector (termina em /conectorCDS). Ex.: http://<host>:<porta>/conectorCDS
SELLBIE_BASE_URL=http://SEU-HOST:PORTA/conectorCDS
# Autenticação CDS: três cabeçalhos (peça ao cliente/CDS).
SELLBIE_API_KEY=            # x_api_key
SELLBIE_API_TOKEN=         # x_api_token
SELLBIE_CLIENT_ID=         # x_cliente_id
# Basic auth legado — a CDS não usa; deixe em branco.
SELLBIE_USERNAME=
SELLBIE_PASSWORD=
# Nome do "vendedor" registrado nas vendas online exportadas ao ERP
# (campo funcionario do POST /cds/inserirvenda).
SELLBIE_EXPORT_SELLER=ECOMMERCE

# Janela de uso da API (horário local). A CDS não documenta janela de horário;
# em live, mantenha SELLBIE_IGNORE_WINDOW=true a menos que a CDS imponha uma.
SELLBIE_WINDOW_START=06:00
SELLBIE_WINDOW_END=07:00
SELLBIE_IGNORE_WINDOW=true

# ─── Sincronização ───────────────────────────────────────────────────────────
# Expressão cron do job diário (padrão: 06:00 todos os dias).
SYNC_CRON=0 6 * * *
# Fuso usado pelo agendador.
SYNC_TIMEZONE=America/Sao_Paulo
# Rodar uma sincronização ao iniciar a API (em mock, recomendado true).
SYNC_ON_BOOT=true
